list.indexOf("사과");   // 인덱스 반환

// 수정
list.set(0, "포도");    // 인덱스 위치 값 교체

// 삭제
list.remove(0);         // 인덱스로 삭제
list.remove("사과");    // 값으로 삭제
list.clear();           // 전체 삭제

// 순회
for (String s : list) { System.out.println(s); }
list.forEach(s -> System.out.println(s));

-- String 특징
String은 불변(immutable) 객체 → 값 변경 시 새 객체 생성

String s1 = "hello";       // 리터럴 (String Pool)
String s2 = new String("hello");  // 힙 메모리에 새 객체

s1 == s2       // false (주소 비교)
s1.equals(s2)  // true  (값 비교) ← 항상 equals 사용!
String + 연산 반복 → 매번 새 객체 생성 → 성능 낮음 → StringBuilder 사용 권장

