- 클래스 관련 키워드

// 일반 클래스
public class Animal {
    private String name;   // 캡슐화
    public Animal(String name) { this.name = name; }
}

// 추상 클래스 - 인스턴스 생성 불가, 추상 메서드 포함 가능
public abstract class Shape {
    abstract double area();  // 추상 메서드 (구현 없음)
