// 예시들
(int a, int b) -> a + b           // 두 수 더하기
(a, b) -> a + b                   // 타입 생략 가능
a -> a * 2                        // 매개변수 1개, 괄호 생략 가능
() -> System.out.println("Hi")    // 매개변수 없음
(a, b) -> { int c = a+b; return c; }  // 여러 문장

// 함수형 인터페이스
@FunctionalInterface
interface Calculator {
    int calc(int a, int b);
}
Calculator add = (a, b) -> a + b;
System.out.println(add.calc(3, 4));  // 7

