import java.util.ArrayList;
import java.util.List;

List<String> list = new ArrayList<>();

// 추가
list.add("사과");
list.add(0, "배");       // 인덱스에 삽입

// 조회
list.get(0);            // 인덱스로 접근
list.size();            // 크기
